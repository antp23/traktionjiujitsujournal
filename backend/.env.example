# Backend runtime configuration. Copy to backend/.env for local use or set these
# variables in your production host. Do not commit real secrets.

# Public frontend origins allowed to call the API.
BJJ_CORS_ORIGINS=https://bjj-tracker.example.com

# Public frontend URL used when building email sign-in links.
BJJ_FRONTEND_URL=https://bjj-tracker.example.com

# Optional shared API key for non-session-protected routes.
# If set here, set the same value as VITE_API_KEY in the frontend environment.
BJJ_TRACKER_API_KEY=replace-with-long-random-value

# SQLite is the current launch database. Use a durable mounted path in production.
BJJ_SQLITE_PATH=/var/lib/bjj-tracker/bjj.db

# Optional SQLAlchemy URL override. Postgres still needs a migration pass before
# team launch; keep SQLite for the first private alpha unless that work is done.
# BJJ_DATABASE_URL=sqlite:////var/lib/bjj-tracker/bjj.db

# Keep WhatsApp capture disabled for the initial launch.
# BJJ_ENABLE_WHATSAPP_CAPTURE=true
# BJJ_META_VERIFY_TOKEN=replace-with-long-random-value
# BJJ_META_APP_SECRET=replace-with-meta-app-secret

# Optional Oura integration.
# OURA_CLIENT_ID=replace-with-oura-client-id
# OURA_CLIENT_SECRET=replace-with-oura-client-secret
# OURA_REDIRECT_URI=https://api.example.com/oura/callback

# Local development only: exposes dev magic-link tokens in API responses.
BJJ_DEV_AUTH_TOKENS=false

# SMTP email delivery for sign-in links. Required when BJJ_DEV_AUTH_TOKENS=false
# and users need to request their own login links.
BJJ_EMAIL_FROM="BJJ Tracker <no-reply@example.com>"
BJJ_SMTP_HOST=smtp.example.com
BJJ_SMTP_PORT=465
BJJ_SMTP_USERNAME=replace-with-smtp-user
BJJ_SMTP_PASSWORD=replace-with-smtp-password
BJJ_SMTP_USE_SSL=true
BJJ_SMTP_USE_TLS=false

# Auth token lifetimes.
BJJ_AUTH_MAGIC_LINK_TTL_MINUTES=15
BJJ_AUTH_SESSION_TTL_HOURS=720

# Auth request throttling.
BJJ_AUTH_REQUEST_LIMIT=5
BJJ_AUTH_REQUEST_WINDOW_MINUTES=15

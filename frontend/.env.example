# Frontend build-time configuration. Vite exposes VITE_* values to the browser,
# so never put private backend-only secrets here.

VITE_API_URL=https://api.example.com

# Optional shared API key for backend routes protected by BJJ_TRACKER_API_KEY.
# This is visible in browser assets; use only as a thin launch guard, not as
# strong user authentication.
# VITE_API_KEY=replace-with-same-value-as-backend
